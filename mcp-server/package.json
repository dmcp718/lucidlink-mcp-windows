{
  "name": "@lucidlink/mcp-server",
  "version": "2.5.4",
  "description": "LucidLink MCP servers — cross-platform filespace management via Claude Desktop",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "lucidlink-api": "./dist/lucid-api-server.js",
    "lucidlink-filespace": "./dist/filespace-server.js",
    "lucidlink-audit-trail": "./dist/audit-trail-server.js",
    "lucidlink-python-sdk": "./dist/python-sdk-server.js",
    "lucidlink-mcp-setup": "./dist/setup.js"
  },
  "files": [
    "dist/",
    "src/docs/chunks/",
    "src/python-sdk/chunks/",
    "src/search/",
    "src/blueprints/audit-dashboard-assets/",
    "mcp-servers.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc -p test/tsconfig.json && node --test dist-test/*.test.js",
    "test:build": "tsc && tsc -p test/tsconfig.json",
    "lucid-api": "node dist/lucid-api-server.js",
    "filespace": "node dist/filespace-server.js",
    "audit-trail": "node dist/audit-trail-server.js",
    "python-sdk": "node dist/python-sdk-server.js",
    "setup": "node dist/setup.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
